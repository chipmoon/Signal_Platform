# Trading System Configuration
# Copy this to .env and fill in values

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SMC_BOT_TOKEN=
TELEGRAM_SMC_CHAT_ID=

# Default ticker
DEFAULT_TICKER=GC=F
DEFAULT_COMMODITY=GOLD

# Mozy Social post monitor (optional)
# Override when your Mozy CLI uses a different Social post command shape.
# Available placeholders: {query}, {symbol}, {limit}
MOZYFIN_SOCIAL_POST_COMMAND=social-post --query {query} --limit {limit}
MOZYFIN_TIMEOUT_SEC=45
